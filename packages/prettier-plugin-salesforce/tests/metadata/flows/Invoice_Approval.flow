<?xml version="1.0" encoding="UTF-8"?><Flow xmlns="http://soap.sforce.com/2006/04/metadata"><apiVersion>63.0</apiVersion><description>Invoice approval flow</description><interviewLabel>Invoice Approval {!$Flow.CurrentDateTime}</interviewLabel><label>Invoice Approval</label><processType>Flow</processType><start><locationX>40</locationX><locationY>0</locationY><connector><targetReference>Check_Amount</targetReference></connector><object>Invoice__c</object><recordTriggerType>CreateAndUpdate</recordTriggerType><triggerType>RecordAfterSave</triggerType></start><decisions><name>Check_Amount</name><label>Check Amount</label><locationX>220</locationX><locationY>120</locationY><defaultConnector><targetReference>Set_Status_Rejected</targetReference></defaultConnector><rules><name>Needs_Approval</name><conditionLogic>and</conditionLogic><conditions><leftValueReference>$Record.Amount__c</leftValueReference><operator>GreaterThan</operator><rightValue><numberValue>1000</numberValue></rightValue></conditions><connector><targetReference>Set_Status_Pending</targetReference></connector><label>Needs Approval</label></rules></decisions><recordUpdates><name>Set_Status_Pending</name><label>Set Status Pending</label><locationX>120</locationX><locationY>280</locationY><inputAssignments><field>Status__c</field><value><stringValue>Pending</stringValue></value></inputAssignments><inputReference>$Record</inputReference></recordUpdates><recordUpdates><name>Set_Status_Rejected</name><label>Set Status Rejected</label><locationX>340</locationX><locationY>280</locationY><inputAssignments><field>Status__c</field><value><stringValue>Rejected</stringValue></value></inputAssignments><inputReference>$Record</inputReference></recordUpdates><status>Active</status></Flow>
