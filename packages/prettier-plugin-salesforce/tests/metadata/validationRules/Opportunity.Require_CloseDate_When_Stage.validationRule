<ValidationRule><active>true</active><description>Closed stages must include a close date and non-zero amount.</description><errorConditionFormula>AND(OR(ISPICKVAL(StageName, "Closed Won"), ISPICKVAL(StageName, "Closed Lost")), OR(ISBLANK(CloseDate), Amount = 0))</errorConditionFormula><errorDisplayField>CloseDate</errorDisplayField><errorMessage>Closed opportunities need a close date and amount.</errorMessage><fullName>Opportunity.Require_CloseDate_When_Stage</fullName></ValidationRule>
