<ValidationRule><active>true</active><description>Business contacts cannot use personal email domains when active.</description><errorConditionFormula>AND(IsActive__c, NOT(ISBLANK(Email)), OR(CONTAINS(LOWER(Email), "@gmail.com"), CONTAINS(LOWER(Email), "@yahoo.com"), CONTAINS(LOWER(Email), "@hotmail.com")))</errorConditionFormula><errorDisplayField>Email</errorDisplayField><errorMessage>Use a business email address for active contacts.</errorMessage><fullName>Contact.Prevent_Personal_Email</fullName></ValidationRule>
