<?xml version="1.0" encoding="UTF-8"?><SharingRules xmlns="http://soap.sforce.com/2006/04/metadata"><sharingCriteriaRules><accessLevel>Edit</accessLevel><description>Escalated cases shared with managers</description><label>Escalated Cases</label><sharedTo><rolesAndSubordinatesInternal>Support_Manager</rolesAndSubordinatesInternal></sharedTo><booleanFilter>1 AND 2</booleanFilter><criteriaItems><field>Case.Priority</field><operation>equals</operation><value>High</value></criteriaItems><criteriaItems><field>Case.IsEscalated</field><operation>equals</operation><value>true</value></criteriaItems></sharingCriteriaRules><sharingOwnerRules><accessLevel>Read</accessLevel><label>Owner Queue Visibility</label><sharedTo><allInternalUsers>true</allInternalUsers></sharedTo><sharedFrom><roles>Support_Agent</roles></sharedFrom></sharingOwnerRules></SharingRules>
