<?xml version="1.0" encoding="UTF-8"?><SharingRules xmlns="http://soap.sforce.com/2006/04/metadata"><sharingCriteriaRules><accessLevel>Read</accessLevel><label>Sibling Risk A</label><description>Queue share when score &gt; 50</description><sharedTo><rolesAndSubordinatesInternal>Support_Manager</rolesAndSubordinatesInternal></sharedTo><booleanFilter>1</booleanFilter><criteriaItems><field>Case.Priority</field><operation>equals</operation><value>High</value></criteriaItems></sharingCriteriaRules><!-- between repeated sibling blocks --><sharingCriteriaRules><accessLevel>Edit</accessLevel><label>Sibling Risk B</label><description>Escalation window &lt; 24h</description><sharedTo><allInternalUsers>true</allInternalUsers></sharedTo><booleanFilter>1</booleanFilter><criteriaItems><field>Case.IsEscalated</field><operation>equals</operation><value>true</value></criteriaItems></sharingCriteriaRules></SharingRules>
