<?xml version="1.0" encoding="UTF-8"?><AuthProvider xmlns="http://soap.sforce.com/2006/04/metadata"><consumerKey>client-key-001</consumerKey><consumerSecret>client-secret-001</consumerSecret><customMetadataTypeRecord>AuthCfg__mdt.Default</customMetadataTypeRecord><executionUser>integration.user@example.com</executionUser><friendlyName>Okta &gt; SSO</friendlyName><iconUrl>https://example.com/icon.png</iconUrl><registrationHandler>ApexRegistrationHandler</registrationHandler><sendAccessTokenInHeader>true</sendAccessTokenInHeader><tokenUrl>https://id.example.com/oauth/token</tokenUrl><userinfoUrl>https://id.example.com/oauth/userinfo</userinfoUrl><urlsuffix>okta-main</urlsuffix><plugin>OpenIdConnect</plugin><plugin>OpenIdConnectFallback</plugin><!-- comment between repeated siblings --><plugin>OpenIdConnectAudit</plugin></AuthProvider>
