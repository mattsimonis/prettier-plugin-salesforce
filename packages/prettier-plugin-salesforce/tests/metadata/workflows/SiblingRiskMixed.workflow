<?xml version="1.0" encoding="UTF-8"?><Workflow xmlns="http://soap.sforce.com/2006/04/metadata"><rules><fullName>Sibling_Risk_One</fullName><active>true</active><booleanFilter>1</booleanFilter><criteriaItems><field>Status</field><operation>equals</operation><value>New</value></criteriaItems><description>Risk score &gt; 3</description><actions><name>Notify_Owner</name><type>Alert</type></actions></rules><!-- keep sibling order stable --><rules><fullName>Sibling_Risk_Two</fullName><active>false</active><booleanFilter>1</booleanFilter><criteriaItems><field>Priority</field><operation>equals</operation><value>High</value></criteriaItems><description>Threshold &lt; baseline</description><actions><name>Flag_Record</name><type>FieldUpdate</type></actions></rules></Workflow>
