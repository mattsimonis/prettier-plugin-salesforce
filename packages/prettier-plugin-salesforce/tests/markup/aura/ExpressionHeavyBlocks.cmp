<aura:component><aura:attribute name="rows" type="List"/><aura:if isTrue="{!v.showRows}"><aura:iteration items="{!v.rows}" var="row"><aura:html tag="span"/><aura:if isTrue="{!row.visible}"><aura:text>{!row.Name + ' / ' + v.suffix}</aura:text><aura:unescapedHtml value="{!v.htmlById[row.Id]}"/></aura:if><aura:set attribute="else"><aura:text>{!v.emptyLabel}</aura:text></aura:set><aura:html tag="br"/></aura:iteration></aura:if></aura:component>
